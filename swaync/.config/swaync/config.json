{
    "$schema": "/etc/xdg/swaync/configSchema.json",
    "ignore-gtk-theme": true,
    "positionX": "right",
    "positionY": "top",
    "layer": "overlay",
    "control-center-layer": "top",
    "layer-shell": true,
    "layer-shell-cover-screen": true,
    "cssPriority": "user",

    "fit-to-screen": false,
    "control-center-width": 400,
    "control-center-height": 1200,
    "control-center-margin-top": 15,
    "control-center-margin-bottom": 0,
    "control-center-margin-right": 15,
    "control-center-margin-left": 0,

    "notification-window-width": 400,
    "notification-window-height": 600,
    "notification-body-image-height": 160,
    "notification-body-image-width": 200,

    "notification-2fa-action": true,
    "notification-inline-replies": false,
    "notification-grouping": true,

    "timeout": 5,
    "timeout-low": 5,
    "timeout-critical": 0,
    "relative-timestamps": true,
    "keyboard-shortcuts": true,
    "image-visibility": "when-available",
    "transition-time": 200,
    "hide-on-clear": false,
    "hide-on-action": true,
    "text-empty": "No Notifications",

    "script-fail-notify": true,
    "scripts": {
        "example-script": {
            "app-name": "example.app.id",
            "exec": "echo 'Do something...'",
            "urgency": "Normal"
        },
        "example-action-script": {
            "app-name": "example.app.id",
            "exec": "echo 'Do something actionable!'",
            "urgency": "Normal",
            "run-on": "action"
        }
    },
    "notification-visibility": {
        "example-name": {
            "state": "muted",
            "urgency": "Normal",
            "app-name": "example.app.id"
        }
    },

    "widgets": [ 
        "label",
        "mpris",
        "buttons-grid",
        "volume",
        "title",
        "notifications"
    ],
    "widget-config": {
        "menubar": {
        },
        "buttons-grid": {
            "buttons-per-row": 5,
            "actions": [
                {
                    "label": "󰖪",
                    "type": "toggle",
                    "command": "bash -c ~/.config/swaync/scripts/toggle-wifi.sh",
                    "active": true,
                    "update-command": "bash -c ~/.config/swaync/scripts/status-wifi.sh"
                },
                {
                    "label": "󰂲",
                    "type": "toggle",
                    "command": "bash -c ~/.config/swaync/scripts/toggle-bluetooth.sh",
                    "active": true,
                    "update-command": "bash -c ~/.config/swaync/scripts/status-bluetooth.sh"
                },
                {
                    "label": "",
                    "type": "toggle",
                    "command": "bash -c ~/.config/swaync/scripts/toggle-mic.sh",
                    "active": true,
                    "update-command": "bash -c ~/.config/swaync/scripts/status-mic.sh"
                },
                {
                    "label": "",
                    "type": "normal",
                    "command": "obs"
                },
                {
                    "label": "󰤄",
                    "type": "toggle",
                    "command": "bash -c ~/.config/swaync/scripts/toggle-dnd.sh",
                    "active": true,
                    "update-command": "echo $(swaync-client -D)"
                }
            ]
        },
        "volume": {
            "label": " ",
            "show-per-app": false
        },
        "notifications": {
            "vexpand": true
        },
        "inhibitors": {
            "text": "Inhibitors",
            "button-text": "All",
            "clear-all-button": true
        },
        "title": {
            "text": "Notifications",
            "clear-all-button": true,
            "button-text": "Clear All"
        },
        "dnd": {
            "text": "Do Not Disturb"
        },
        "label": {
            "max-lines": 1,
            "text": "Control Center"
        },
        "mpris": {
            "blacklist": ["playerctld"],
            "autohide": true,
            "show-album-art": "when-available",
            "loop-carousel": false
        }
    }
}
